  "R": {
    "id": "tag-r",
    "name": "R — Relation",
    "description": "关系的分类。按 L0/L1/L2 分级，边界标准：能否不经人脑/AI完备计算。分级是工程状态快照，可随工程成熟度迁移。",
    "children": {
      "L0_logic": {
        "id": "tag-r-l0",
        "name": "L0 逻辑关系（纯计算，条件确定结果唯一）",
        "description": "L0 逻辑关系（纯计算，条件确定结果唯一）",
        "children": [
          {
            "id": "tag-r-l0-deductive",
            "name": "演绎（前提→结论，必然）"
          },
          {
            "id": "tag-r-l0-inductive",
            "name": "归纳（样本→规律，统计确定）"
          },
          {
            "id": "tag-r-l0-analogical",
            "name": "类比（结构映射，形式确定）"
          }
        ]
      },
      "L1_conditional": {
        "id": "tag-r-l1",
        "name": "L1 条件/时间关系（需人脑/AI辅助，无法穷举）",
        "description": "条件过于复杂无法完备计算。基本元素只有两个：条件关系和时间关系，其余皆为组合演化。",
        "children": {
          "primitives": {
            "id": "tag-r-l1-prim",
            "name": "基本元素",
            "children": [
              {
                "id": "tag-r-l1-condition",
                "name": "条件关系（A存在则B存在的概率）"
              },
              {
                "id": "tag-r-l1-temporal",
                "name": "时间关系（序列/循环/同时）"
              }
            ]
          },
          "compositions": {
            "id": "tag-r-l1-comp",
            "name": "组合演化（条件+时间的组合）",
            "children": [
              {
                "id": "tag-r-l1-causal",
                "name": "因果 = 条件+时间先后（直接/间接/反事实）"
              },
              {
                "id": "tag-r-l1-process",
                "name": "过程 = 时间中的演化（量变积累/质变涌现/条件转化）"
              },
              {
                "id": "tag-r-l1-evolution",
                "name": "发展 = 条件+时间+环境变化"
              }
            ]
          }
        }
      },
      "L2_existential": {
        "id": "tag-r-l2",
        "name": "L2 存在关系（需叙事赋予价值和合法性）",
        "description": "涉及主观、认知、意义、叙事。主体在时空维度上的实践过程。辩证法：矛盾律在L0禁止A∧¬A，但在L2中可控-失控可同时为真。",
        "children": [
