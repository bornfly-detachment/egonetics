## 三、数据库 Schema

### 3.1 memory.db（重写）

```sql
-- 一次完整的 Agent 会话
CREATE TABLE sessions (
  id           TEXT PRIMARY KEY,
  agent_name   TEXT NOT NULL,
  agent_type   TEXT NOT NULL,    -- 'claude_code' | 'openclaw' | 'api'
  model        TEXT,             -- 'claude-sonnet-4-6' / 'deepseek-reasoner' 等
  source_file  TEXT,             -- 原始 jsonl 路径
  token_input  INTEGER DEFAULT 0,
  token_output INTEGER DEFAULT 0,
  duration_ms  INTEGER DEFAULT 0,
  started_at   TEXT,
  ended_at     TEXT,
  created_at   TEXT NOT NULL DEFAULT (datetime('now'))
);

-- 每轮对话：一个用户输入 → 完整响应链
CREATE TABLE rounds (
  id           TEXT PRIMARY KEY,
  session_id   TEXT NOT NULL,
  round_num    INTEGER NOT NULL,
  user_input   TEXT,
  started_at   TEXT,
  ended_at     TEXT,
  duration_ms  INTEGER DEFAULT 0,
  token_input  INTEGER DEFAULT 0,
  token_output INTEGER DEFAULT 0,
  FOREIGN KEY (session_id) REFERENCES sessions(id) ON DELETE CASCADE
);

-- 轮内执行步骤链（thinking → tool_call → tool_result → response）
CREATE TABLE steps (
  id          TEXT PRIMARY KEY,
  round_id    TEXT NOT NULL,
  step_num    INTEGER NOT NULL,
  type        TEXT NOT NULL,    -- 'thinking' | 'tool_call' | 'tool_result' | 'response'
  tool_name   TEXT,             -- tool_call/tool_result 时填写
  content     TEXT DEFAULT '{}', -- JSON，完整内容
  duration_ms INTEGER DEFAULT 0,
  created_at  TEXT NOT NULL DEFAULT (datetime('now')),
  FOREIGN KEY (round_id) REFERENCES rounds(id) ON DELETE CASCADE
);

-- 用户标注（打标签 / 提炼关键信息 / 标记训练数据）
CREATE TABLE annotations (
  id         TEXT PRIMARY KEY,
  ref_type   TEXT NOT NULL,    -- 'round' | 'step' | 'session'
  ref_id     TEXT NOT NULL,
  type       TEXT NOT NULL,    -- 'tag' | 'note' | 'extract' | 'training_data'
  content    TEXT,
  tags       TEXT DEFAULT '[]', -- JSON 数组
  created_at TEXT NOT NULL DEFAULT (datetime('now'))
);

-- Chronicle 事件流（所有模块写入此表，构成时间轴）
CREATE TABLE events (
  id         TEXT PRIMARY KEY,
  type       TEXT NOT NULL,    -- 见下方事件类型清单
  source     TEXT NOT NULL,    -- 'memory' | 'task' | 'agent' | 'theory'
  ref_id     TEXT,             -- 关联的 session_id / task_id / agent_id
  title      TEXT,
  content    TEXT DEFAULT '{}', -- JSON，记录过程细节
  epoch_id   TEXT,             -- 所属版本（Epoch）
  created_at TEXT NOT NULL DEFAULT (datetime('now'))
);

-- Chronicle Epoch 版本（V1 → V2 → ... 用户手动触发）
CREATE TABLE epochs (
  id          TEXT PRIMARY KEY,
  version     INTEGER NOT NULL,  -- 1, 2, 3...
  title       TEXT,
  description TEXT,
  started_at  TEXT NOT NULL DEFAULT (datetime('now')),
  ended_at    TEXT               -- NULL 表示当前版本
);

-- 索引
CREATE INDEX idx_sessions_agent_type ON sessions(agent_type);
CREATE INDEX idx_rounds_session_id   ON rounds(session_id);
CREATE INDEX idx_steps_round_id      ON steps(round_id);
CREATE INDEX idx_events_source       ON events(source);
CREATE INDEX idx_events_created_at   ON events(created_at);
CREATE INDEX idx_events_epoch_id     ON events(epoch_id);
CREATE INDEX idx_annotations_ref     ON annotations(ref_type, ref_id);
```

**events.type 清单：**
```
memory.session_imported   -- 导入了一条对话记录
memory.annotation_added   -- 用户添加了标注
task.created              -- 创建了任务
task.updated              -- 任务状态/内容变更
task.completed            -- 任务完成
agent.started             -- Agent 开始工作
agent.output              -- Agent 产生输出
agent.completed           -- Agent 完成任务
theory.page_created       -- 新建 Theory 页面
theory.page_edited        -- 编辑了 Theory 页面
epoch.created             -- 用户宣告进入新版本
```

### 3.2 agents.db（新建）

```sql
-- Agent 定义
CREATE TABLE agents (
  id          TEXT PRIMARY KEY,
  name        TEXT NOT NULL,
  type        TEXT NOT NULL,     -- 'claude_code' | 'openclaw' | 'api'
  model       TEXT,
  role        TEXT DEFAULT 'worker',  -- 'master' | 'worker'
  description TEXT,
  status      TEXT DEFAULT 'idle',    -- 'idle' | 'running' | 'paused' | 'done'
  position_x  REAL DEFAULT 0,         -- 节点图 X 坐标
  position_y  REAL DEFAULT 0,         -- 节点图 Y 坐标
  created_at  TEXT NOT NULL DEFAULT (datetime('now')),
  updated_at  TEXT NOT NULL DEFAULT (datetime('now'))
);

-- Agent 关系图（两两之间的工作关系）
CREATE TABLE agent_relations (
  id           TEXT PRIMARY KEY,
  from_agent   TEXT NOT NULL,
  to_agent     TEXT NOT NULL,
  type         TEXT NOT NULL,    -- 'parallel' | 'sequential' | 'causal'
  -- parallel:  两者并行工作
  -- sequential: to_agent 在 from_agent 完成后开始
  -- causal:    to_agent 以 from_agent 的输出为输入
  condition    TEXT,             -- JSON，可选的触发条件
  created_at   TEXT NOT NULL DEFAULT (datetime('now')),
  FOREIGN KEY (from_agent) REFERENCES agents(id) ON DELETE CASCADE,
  FOREIGN KEY (to_agent)   REFERENCES agents(id) ON DELETE CASCADE
);

-- Agent 消息记录（agent间通信 + agent与用户通信）
CREATE TABLE agent_messages (
  id         TEXT PRIMARY KEY,
  from_id    TEXT,              -- NULL 表示来自用户
  to_id      TEXT,              -- NULL 表示发给用户
  content    TEXT NOT NULL,
  type       TEXT DEFAULT 'message',  -- 'message' | 'command' | 'output'
  created_at TEXT NOT NULL DEFAULT (datetime('now'))
);

CREATE INDEX idx_agent_messages_from ON agent_messages(from_id);
CREATE INDEX idx_agent_messages_to   ON agent_messages(to_id);
```

