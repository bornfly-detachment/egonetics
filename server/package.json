{
  "name": "egonetics-memory-server",
  "version": "0.1.0",
  "description": "Memory module backend for Egonetics project",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "init-memory": "node scripts/init-memory-db.js",
    "init-tasks": "node scripts/init-tasks-db.js",
    "init-pages": "node scripts/init-pages-db.js",
    "init-agents": "node scripts/init-agents-db.js",
    "migrate": "node scripts/migrate-chronicle.js",
    "import": "node scripts/import-jsonl.js",
    "backup": "node ../scripts/backup-claude-projects.js",
    "backup:daemon": "node ../scripts/backup-claude-projects.js --daemon",
    "backup:dry": "node ../scripts/backup-claude-projects.js --dry-run"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
