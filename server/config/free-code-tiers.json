{
  "_doc": "Free-Code Tier Registry. Each tier defines the model backend, env injection, and session/config isolation strategy for the same free-code binary.",

  "default_tier": "T2",

  "tiers": {
    "T0": {
      "id": "T0",
      "label": "Local Qwen",
      "description": "本地 mlx_lm 推理，零成本，数据不出本机",
      "color": "emerald",
      "enabled": true,
      "spawn_user": "egonetics-l0",
      "default_cwd": "/Users/Shared/prvse_world_workspace/L0",
      "scope": {
        "readable": ["/Users/Shared/prvse_world_workspace/L0", "/Users/Shared/reference"],
        "writable": ["/Users/Shared/prvse_world_workspace/L0"],
        "description": "L0 执行层：沙盒工作区，临时文件、scratch 代码；可读 reference 参考代码"
      },
      "env": {
        "ANTHROPIC_BASE_URL": "http://127.0.0.1:3002",
        "ANTHROPIC_API_KEY": "sk-ant-api03-local-egonetics-t0-placeholder-000000000000000000000000000000000000000000000000",
        "ANTHROPIC_MODEL": "qwen3.5-0.8b",
        "FREE_CODE_CONFIG_DIR": "/Users/Shared/prvse_world_workspace/L0/free-code-config"
      },
      "session_prefix": "freecode-t0",
      "model_hint": "qwen3.5-0.8b",
      "startup_flags": ["--dangerously-skip-permissions", "--add-dir", "/Users/Shared/reference"]
    },

    "T1": {
      "id": "T1",
      "label": "MiniMax 2.7",
      "description": "MiniMax 云端，原生支持 Anthropic 协议，走 egonetics-l1 隔离用户",
      "color": "sky",
      "enabled": true,
      "spawn_user": "egonetics-l1",
      "default_cwd": "/Users/Shared/prvse_world_workspace/L1",
      "scope": {
        "readable": ["/Users/Shared/prvse_world_workspace/L0", "/Users/Shared/prvse_world_workspace/L1", "/Users/Shared/reference"],
        "writable": ["/Users/Shared/prvse_world_workspace/L1"],
        "description": "L1 推理层：可读 L0/L1，读写 L1（客观法则、项目配置）；可读 reference 参考代码"
      },
      "env": {
        "FREE_CODE_CONFIG_DIR": "/Users/Shared/prvse_world_workspace/L1/free-code-config"
      },
      "env_file": "~/.minimax_claude",
      "session_prefix": "freecode-t1",
      "model_hint": "MiniMax-M2.7",
      "startup_flags": ["--dangerously-skip-permissions", "--add-dir", "/Users/Shared/reference"]
    },

    "T2": {
      "id": "T2",
      "label": "Claude Sonnet 4.6",
      "description": "Claude Max 订阅（默认），走 macOS Keychain OAuth — 必须以 host 身份跑",
      "color": "violet",
      "enabled": true,
      "spawn_user": null,
      "default_cwd": "/Users/Shared/prvse_world_workspace/L2",
      "scope": {
        "readable": ["*"],
        "writable": ["*"],
        "description": "T2 作为 host user (bornfly) 运行，拥有全部文件系统权限 — 谨慎使用"
      },
      "env": {
        "FREE_CODE_CONFIG_DIR": "/Users/Shared/prvse_world_workspace/L2/free-code-config"
      },
      "session_prefix": "freecode-t2",
      "model_hint": "claude-sonnet-4-5",
      "startup_flags": ["--dangerously-skip-permissions"],
      "isolation_note": "T2 必须访问 bornfly 的 macOS Keychain 做 OAuth，无法在 isolated user 下运行"
    },

    "T3": {
      "_added_by": "Claude-added (2026-04-18): Codex CLI xterm tier",
      "id": "T3",
      "label": "Codex CLI",
      "description": "OpenAI Codex CLI，走 OpenAI 订阅 OAuth，host 身份运行",
      "color": "green",
      "enabled": true,
      "binary": "/Users/bornfly/.npm-global/bin/codex",
      "spawn_user": null,
      "default_cwd": "/Users/Shared/prvse_world_workspace/L2",
      "scope": {
        "readable": ["*"],
        "writable": ["*"],
        "description": "T3 以 host 身份运行，OAuth 凭证存储在用户目录"
      },
      "env": {},
      "session_prefix": "freecode-t3",
      "model_hint": "codex",
      "startup_flags": [],
      "isolation_note": "T3 必须以 host 身份运行，OAuth 存储在 ~/.codex/"
    },

    "T4": {
      "_added_by": "Claude-added (2026-04-18): Gemini CLI xterm tier",
      "id": "T4",
      "label": "Gemini CLI",
      "description": "Google Gemini CLI，走 Google OAuth 订阅，host 身份运行",
      "color": "blue",
      "enabled": true,
      "binary": "/Users/bornfly/.npm-global/bin/gemini",
      "spawn_user": null,
      "default_cwd": "/Users/Shared/prvse_world_workspace/L2",
      "scope": {
        "readable": ["*"],
        "writable": ["*"],
        "description": "T4 以 host 身份运行，OAuth 凭证存储在用户目录"
      },
      "env": {},
      "session_prefix": "freecode-t4",
      "model_hint": "gemini-2.5-pro",
      "startup_flags": ["--approval-mode", "yolo"],
      "isolation_note": "T4 必须以 host 身份运行，OAuth 存储在 ~/.gemini/"
    }
  }
}
